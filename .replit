modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/birthday-invite"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production pnpm --filter @workspace/api-server run start"]

[deployment.build]
args = ["sh", "-c", "pnpm install && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/birthday-invite run build"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/birthday-invite run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 NODE_ENV=production pnpm --filter @workspace/api-server run start"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
